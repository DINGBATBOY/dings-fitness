# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Firebase — Firebase Console > Project Settings > General > Your Apps
# These VALUES are safe to ship to the client (Google designed them that way).
# Access is gated by Firestore rules + Firebase Auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Gemini — NO LONGER REQUIRED on the client.
# The key now lives as a Firebase Functions secret on the server.
# To set it once:
#   firebase functions:secrets:set GEMINI_API_KEY
# See DEPLOY.md for the full procedure.

# Optional — set to "true" to point the client at local Firebase emulators.
# Useful for development without burning real Gemini quota.
VITE_USE_FIREBASE_EMULATORS=
